# Minimal public-safe example.
# Additional optional settings live in backend/core/config.py.

ACCOUNT_MODE=DEMO
TERMINAL_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
MT5_CONNECT_TIMEOUT_MS=4000
MT5_CONNECT_RETRY_DELAY_SEC=10

DEMO_MT5_LOGIN=0
DEMO_MT5_PASSWORD=
DEMO_MT5_SERVER=

REAL_MT5_LOGIN=0
REAL_MT5_PASSWORD=
REAL_MT5_SERVER=

# Telegram basic
TELEGRAM_BOT_TOKEN=
# Runtime DM / Trading_Bot route
TELEGRAM_CHAT_ID=

# Telegram room split
# Check room can be a standalone room. Leave topic blank in that case.
TELEGRAM_CHECK_CHAT_ID=
TELEGRAM_CHECK_TOPIC_ID=

# Report room can be a standalone room or a forum topic.
TELEGRAM_REPORT_CHAT_ID=
TELEGRAM_REPORT_TOPIC_ID=

# PnL forum topics
TELEGRAM_PNL_FORUM_CHAT_ID=
TELEGRAM_PNL_TOPIC_15M_ID=
TELEGRAM_PNL_TOPIC_1H_ID=
TELEGRAM_PNL_TOPIC_4H_ID=
TELEGRAM_PNL_TOPIC_1D_ID=
TELEGRAM_PNL_TOPIC_1W_ID=
TELEGRAM_PNL_TOPIC_1M_ID=

# Telegram approval operators
TELEGRAM_ALLOWED_USER_IDS=

# Telegram ops toggles
TELEGRAM_OPS_ENABLED=true
TELEGRAM_OPS_STATE_PATH=data\runtime\telegram_ops_state.json
TELEGRAM_OPS_BOOTSTRAP_ENABLED=true
TELEGRAM_OPS_CALLBACK_POLL_SEC=2
TELEGRAM_OPS_PNL_SCAN_SEC=15
TELEGRAM_OPS_CHECK_SCAN_SEC=5
TELEGRAM_OPS_CHECK_MAX_PENDING=5
TELEGRAM_OPS_CHECK_MIN_CONFIDENCE=0.58
# Runtime entry/wait/exit approvals stay off. Telegram is for improvement review only.
TELEGRAM_OPS_LIVE_CHECK_APPROVALS_ENABLED=false

# Storage retention / historical cleanup
CFD_STORAGE_RETENTION_CAP_GB=20
CFD_STORAGE_RETENTION_WATCH_ENABLED=true
CFD_STORAGE_RETENTION_WATCH_INTERVAL_MIN=60
CFD_STORAGE_RETENTION_RUNTIME_TRIM_ENABLED=true
CFD_STORAGE_RETENTION_CHECKPOINT_DETAIL_MIN_GB=2

WATCH_LIST=NAS100,XAUUSD,BTCUSD
DEFAULT_SYMBOL=NAS100
TIMEZONE=Asia/Seoul

ENTRY_THRESHOLD=300
AI_ENTRY_THRESHOLD=0.58
AI_EXIT_THRESHOLD=0.55

ENTRY_DECISION_LOG_PATH=data\trades\entry_decisions.csv
TRADE_HISTORY_CSV_PATH=data\trades\trade_history.csv
CLOSED_TRADE_CSV_PATH=data\trades\trade_closed_history.csv
